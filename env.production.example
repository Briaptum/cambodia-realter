# Production Environment Configuration
# Copy this file to .env for production deployment

# Database Configuration (External PostgreSQL)
DATABASE_URL=postgres://username:password@your-db-host:5432/go_vue_base?sslmode=require
DB_HOST=your-db-host
DB_PORT=5432
DB_USER=username
DB_PASSWORD=password
DB_NAME=go_vue_base
DB_SSLMODE=require

# Server Configuration
GIN_MODE=release

# Docker Port Configuration (customize for your server)
BACKEND_PORT=8005
FRONTEND_PORT=4002

# Auth0 Configuration
AUTH0_DOMAIN=your-domain.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret
JWT_SECRET=your-production-jwt-secret-key-make-this-very-secure

# Site Configuration
SITE_ID=go-vue-base
SITE_URL=https://yourdomain.com

# Email Configuration (Production)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
SMTP_FROM=noreply@yourdomain.com
NOTIFICATION_EMAILS=admin@yourdomain.com,support@yourdomain.com
SENDGRID_API_KEY=your-sendgrid-api-key

# Frontend Configuration
NODE_ENV=production
VITE_API_URL=https://api.yourdomain.com

# Security
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
