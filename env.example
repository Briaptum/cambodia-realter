# Database Configuration
# For local development with Docker Compose, use the postgres service hostname
# For production, use your external database connection details
DB_HOST=postgres
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=go_vue_base
DB_PORT=5432
DB_SSLMODE=disable
# For production, set DB_SSLMODE=require

# Backend Configuration
PORT=8080
GIN_MODE=debug
GO_ENV=development

# Docker Port Configuration (for docker-compose)
BACKEND_PORT=8080
FRONTEND_PORT=3000

# Frontend Configuration
NODE_ENV=development
SITE_URL=http://localhost:3000

# Auth0 Configuration (Required)
AUTH0_DOMAIN=your-auth0-domain.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
JWT_SECRET=your-jwt-secret-key
SITE_ID=go-vue-base

# Email Configuration (Local Development with MailHog)
# - If backend runs in Docker: use SMTP_HOST=mailhog, SMTP_PORT=1025
# - If backend runs locally: use SMTP_HOST=localhost, SMTP_PORT=1026
# 
# For local development, MailHog is used (no SendGrid API key needed)
# For production, set SENDGRID_API_KEY instead
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@go-vue-base.com
NOTIFICATION_EMAILS=admin@example.com

# SendGrid API Key (only needed for production)
SENDGRID_API_KEY=

# Frontend Vite Configuration
VITE_API_URL=http://localhost:8080
